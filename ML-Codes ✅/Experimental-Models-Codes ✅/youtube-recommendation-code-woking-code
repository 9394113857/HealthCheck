pred.est, 4)\n","\n","            for pred in top_predictions\n","        ]\n","\n","    })\n","\n","    # --------------------------------------------------------\n","    # DISPLAY\n","    # --------------------------------------------------------\n","\n","    print(\n","        f\"\\n🎬 Top 10 Recommendations \"\n","        f\"for User ID: {target_uid}\"\n","    )\n","\n","    display(\n","        recommendations_df\n","    )\n","\n","    # --------------------------------------------------------\n","    # RETURN DATAFRAME\n","    # --------------------------------------------------------\n","\n","    return recommendations_df"],"execution_count":null,"outputs":[]},{"cell_type":"code","source":[],"metadata":{"id":"VtaoY7ZQXTq0"},"execution_count":null,"outputs":[]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":971},"id":"d861a6e4","executionInfo":{"status":"ok","timestamp":1780407560631,"user_tz":-330,"elapsed":3441,"user":{"displayName":"practice session","userId":"06899126492144380653"}},"outputId":"ac6aed38-d2b7-4f1c-a311-cd3110357f45"},"source":["# ============================================================\n","# USER INPUT + RECOMMENDATION SYSTEM 🚀\n","# ============================================================\n","\n","import pandas as pd\n","from IPython.display import display\n","\n","# ============================================================\n","# DEFAULT USER ID\n","# ============================================================\n","\n","default_user_id = 486\n","\n","# ============================================================\n","# USER INPUT SECTION\n","# ============================================================\n","\n","print(\"=\" * 70)\n","print(\"🧠 USER INPUT SECTION\")\n","print(\"=\" * 70)\n","\n","print(f\"\"\"\n","📌 DEFAULT USER ID:\n","{default_user_id}\n","\n","👉 Press ENTER for default value\n","👉 Or enter another User ID\n","\"\"\")\n","\n","# =============================================