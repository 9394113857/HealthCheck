 1 - DEFINE GOOGLE DRIVE SAVE PATH\n","# ============================================================\n","\n","save_base_path = (\n","    '/content/gdrive/MyDrive/'\n","    '2026 Hands On/ML-Folder ✅/Experimental-Models ✅'\n",")\n","\n","# Create folder if not exists\n","os.makedirs(save_base_path, exist_ok=True)\n","\n","print(\"=\" * 70)\n","print(\"📂 SAVE DIRECTORY:\")\n","print(save_base_path)\n","print(\"=\" * 70)\n","\n","# ============================================================\n","# STEP 2 - DEFINE BASE FILENAMES\n","# ============================================================\n","\n","vectorizer_base_name = \"tfidf_vectorizer\"\n","df_base_name = \"processed_df\"\n","\n","# ============================================================\n","# STEP 3 - FIND EXISTING VERSION FILES\n","# ============================================================\n","\n","existing_vectorizer_files = glob.glob(\n","    os.path.join(\n","        save_base_path,\n","        f\"{vectorizer_base_name}_v*.pkl\"\n","    )\n",")\n","\n","existing_df_files = glob.glob(\n","    os.path.join(\n","        save_base_path,\n","        f\"{df_base_name}_v*.parquet\"\n","    )\n",")\n","\n","# ============================================================\n","# STEP 4 - FUNCTION TO GET NEXT VERSION\n","# ============================================================\n","\n","def get_next_version(file_list, base_name):\n","\n","    versions = []\n","\n","    for file in file_list:\n","\n","        filename = os.path.basename(file)\n","\n","        # ----------------------------------------------------\n","        # EXTRACT VERSION NUMBER\n","        # Example:\n","        # tfidf_vectorizer_v3.pkl\n","        # ----------------------------------------------------\n","\n","        match = re.search(\n","            rf\"{base_name}_v(\\d+)\",\n","            filename\n","        )\n","\n","        if match:\n","\n","            versions.append(\n","                int(match.group(1))\n","      