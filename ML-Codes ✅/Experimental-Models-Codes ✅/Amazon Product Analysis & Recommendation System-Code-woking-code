to re-import the recommendation function if the notebook was restarted\n","# and you are running cells out of order, or if this cell is executed independently.\n","# For continuous execution, it might already be defined.\n","\n","# Re-define the recommendation function to ensure it's available in this scope\n","# This block is copied from cell c0ae1166 to make this cell self-contained if run after a restart\n","from sklearn.metrics.pairwise import cosine_similarity\n","\n","def recommend_products_from_loaded(df, tfidf_vectorizer, tfidf_matrix, user_id_encoded):\n","    user_history = df[df['user_id_encoded'] == user_id_encoded]\n","    indices = user_history.index.tolist()\n","\n","    if indices:\n","        cosine_sim_user = cosine_similarity(tfidf_matrix[indices], tfidf_matrix)\n","        products = df.iloc[indices]['product_name']\n","        product_indices_series = pd.Series(products.index, index=products)\n","\n","        similarity_scores = list(enumerate(cosine_sim_user[-1]))\n","        similarity_scores = [(i, score) for (i, score) in similarity_scores if i not in product_indices_series]\n","        similarity_scores = sorted(similarity_scores, key=lambda x: x[1], reverse=True)\n","\n","        top_products = [i[0] for i in similarity_scores[1:6]]\n","        recommended_products = df.iloc[top_products]['product_name'].tolist()\n","        score = [similarity_scores[i][1] for i in range(5)]\n","\n","        results_df = pd.DataFrame({'Id Encoded': [user_id_encoded] * 5,\n","                                   'recommended product': recommended_products,\n","                                   'score recommendation': score})\n","        return results_df\n","    else:\n","        print(\"No purchase history found for this user in the loaded data.\")\n","        return None\n","\n","# Hardcoded user ID for demonstration\n","# You can change this to any valid user_id_encoded from your dataset\n","demo_user_id_for_prediction = 1045 # This user has 10 reviews in the original df\n","\n","print(f\"\\n🚀 GENERATING RECOMMENDATIONS FOR USER ID ENCODED: {demo_user_id_for_prediction}\\n\")\n","\n","# Generate recommendations using the loaded components and the hardcoded user ID\n","recommendations_for_user = recommend_products_from_loaded(\n","    loaded_df,\n","    loaded_tfidf_vectorizer,\n","    loaded_tfidf_matrix,\n","    demo_user_id_for_prediction\n",")\n","\n","# Display the recommendations in a tabular format\n","if recommendations_for_user is not None:\n","    print(\"✅ RECOMMENDATIONS GENERATED SUCCESSFULLY!\\n\")\n","    print(\"📊 DISPLAYING TOP 5 RECOMMENDATIONS:\\n\")\n","    display(recommendations_for_user)\n","else:\n","    print(\"⚠️ Could not generate recommendations for the specified user.\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","🚀 GENERATING RECOMMENDATIONS FOR USER ID ENCODED: 1045\n","\n","✅ RECOMMENDATIONS GENERATED SUCCESSFULLY!\n","\n","📊 DISPLAYING TOP 5 RECOMMENDATIONS:\n","\n"]},{"output_type":"display_data","data":{"text/plain":["   Id Encoded                                recommended product  \\\n","0        1045        Flix Micro Usb Cable For Smartphone (Black)   \n","1        1045        Flix Micro Usb Cable For Smartphone (Black)   \n","2        1045  FLiX (Beetel USB to Micro USB PVC Data Sync & ...   \n","3        1045  pTron Solero M241 2.4A Micro USB Data & Chargi...   \n","4        1045  Flix (Beetel) Usb To Type C Pvc Data Sync And ...   \n","\n","   score recommendation  \n","0              1.000000  \n","1              1.000000  \n","2              1.000000  \n","3              0.911776  \n","4              0.677536  "],"text/html":["\n","  <div id=\"df-b86433c7-683e-493c-992f-b9618d3882a5\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","  